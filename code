<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AURA – Autonomous Education Coach</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080c14;
    --surface: #0e1420;
    --surface2: #131b2a;
    --border: rgba(100,180,255,0.08);
    --accent: #3b82f6;
    --accent2: #06d6a0;
    --accent3: #f59e0b;
    --accent4: #ec4899;
    --text: #e8edf5;
    --muted: #6b7a95;
    --glow: rgba(59,130,246,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Glow blobs */
  .blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.25;
    pointer-events: none;
    z-index: 0;
  }
  .blob1 { width: 500px; height: 500px; background: #1e40af; top: -150px; right: -100px; }
  .blob2 { width: 350px; height: 350px; background: #065f46; bottom: 0; left: -80px; }

  /* Layout */
  .layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 100vh;
  }

  /* Sidebar */
  .sidebar {
    background: var(--surface);
    border-right: 1px solid var(--border);
    padding: 28px 0;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
  }

  .logo {
    padding: 0 24px 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 20px;
  }
  .logo-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .logo-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 10px;
    display: grid;
    place-items: center;
    font-size: 18px;
    box-shadow: 0 0 20px var(--glow);
  }
  .logo-text {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.5px;
    background: linear-gradient(90deg, #fff, #94a3b8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .logo-sub { font-size: 11px; color: var(--muted); margin-top: 2px; letter-spacing: 0.5px; }

  .nav-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--muted);
    padding: 0 24px;
    margin-bottom: 6px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 24px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all 0.2s;
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 2px;
  }
  .nav-item:hover { background: var(--glow); color: var(--text); }
  .nav-item.active {
    border-left-color: var(--accent);
    background: rgba(59,130,246,0.1);
    color: var(--accent);
    font-weight: 500;
  }
  .nav-icon { font-size: 16px; width: 20px; text-align: center; }

  .sidebar-footer {
    margin-top: auto;
    padding: 20px 24px;
    border-top: 1px solid var(--border);
  }
  .learner-card {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .avatar {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 14px;
  }
  .learner-info { flex: 1; min-width: 0; }
  .learner-name { font-size: 13px; font-weight: 500; }
  .learner-role { font-size: 11px; color: var(--muted); }
  .online-dot { width: 8px; height: 8px; background: var(--accent2); border-radius: 50%; }

  /* Main content */
  .main {
    display: flex;
    flex-direction: column;
  }

  /* Topbar */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    border-bottom: 1px solid var(--border);
    background: rgba(8,12,20,0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .topbar-title { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; }
  .topbar-meta { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .topbar-actions { display: flex; align-items: center; gap: 12px; }
  .badge-pill {
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-green { background: rgba(6,214,160,0.15); color: var(--accent2); border: 1px solid rgba(6,214,160,0.2); }
  .badge-blue { background: rgba(59,130,246,0.15); color: var(--accent); border: 1px solid rgba(59,130,246,0.2); }

  /* Content area */
  .content { padding: 24px 28px; flex: 1; }

  /* Sections */
  .section { display: none; }
  .section.active { display: block; }

  /* Cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
  }
  .card-sm { padding: 18px 20px; }

  /* Stats row */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
  }
  .stat-card:hover { transform: translateY(-2px); border-color: rgba(100,180,255,0.2); }
  .stat-card::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 60px; height: 60px;
    border-radius: 50%;
    opacity: 0.1;
    transform: translate(20px, -20px);
  }
  .stat-card.blue::after { background: var(--accent); }
  .stat-card.green::after { background: var(--accent2); }
  .stat-card.amber::after { background: var(--accent3); }
  .stat-card.pink::after { background: var(--accent4); }

  .stat-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 8px; }
  .stat-value { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; }
  .stat-value.blue { color: var(--accent); }
  .stat-value.green { color: var(--accent2); }
  .stat-value.amber { color: var(--accent3); }
  .stat-value.pink { color: var(--accent4); }
  .stat-change { font-size: 12px; color: var(--muted); margin-top: 4px; }
  .stat-change .up { color: var(--accent2); }
  .stat-change .down { color: #f87171; }

  /* Two column grid */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .grid-3 { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px; }

  /* Section header */
  .sec-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .sec-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; }
  .sec-action { font-size: 12px; color: var(--accent); cursor: pointer; }

  /* Progress bars */
  .progress-item { margin-bottom: 14px; }
  .progress-label { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 6px; }
  .progress-pct { color: var(--muted); font-size: 12px; }
  .progress-bar {
    height: 6px;
    background: var(--surface2);
    border-radius: 100px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 100px;
    position: relative;
    transition: width 1s ease;
  }
  .progress-fill::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2));
    animation: shimmer 2s infinite;
  }
  @keyframes shimmer { 0%,100%{opacity:0} 50%{opacity:1} }

  /* Learning path */
  .path-item {
    display: flex;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
    cursor: pointer;
    transition: background 0.15s;
  }
  .path-item:last-child { border-bottom: none; }
  .path-item:hover { background: var(--glow); border-radius: 8px; padding: 14px 8px; margin: 0 -8px; }
  .path-num {
    width: 28px; height: 28px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .path-done { background: rgba(6,214,160,0.2); color: var(--accent2); }
  .path-active { background: rgba(59,130,246,0.2); color: var(--accent); }
  .path-locked { background: var(--surface2); color: var(--muted); }
  .path-title { font-size: 14px; font-weight: 500; }
  .path-meta { font-size: 12px; color: var(--muted); margin-top: 3px; }
  .path-tag {
    margin-left: auto;
    padding: 3px 8px;
    border-radius: 100px;
    font-size: 11px;
    white-space: nowrap;
  }
  .tag-done { background: rgba(6,214,160,0.1); color: var(--accent2); }
  .tag-active { background: rgba(59,130,246,0.1); color: var(--accent); }
  .tag-locked { background: var(--surface2); color: var(--muted); }

  /* AI Insights */
  .insight-item {
    display: flex;
    gap: 14px;
    padding: 14px;
    border-radius: 10px;
    background: var(--surface2);
    margin-bottom: 10px;
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  .insight-item:hover { border-color: rgba(59,130,246,0.3); }
  .insight-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .insight-text { font-size: 13px; line-height: 1.5; }
  .insight-source { font-size: 11px; color: var(--muted); margin-top: 4px; }

  /* Chart area */
  .chart-area { height: 160px; position: relative; }
  canvas { width: 100% !important; }

  /* Agents panel */
  .agent-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .agent-item:last-child { border-bottom: none; }
  .agent-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .agent-dot.active { background: var(--accent2); box-shadow: 0 0 8px var(--accent2); animation: pulse 2s infinite; }
  .agent-dot.idle { background: var(--accent3); }
  .agent-dot.standby { background: var(--muted); }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
  .agent-name { font-size: 13px; font-weight: 500; flex: 1; }
  .agent-task { font-size: 11px; color: var(--muted); }
  .agent-status {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 100px;
  }
  .agent-status.running { background: rgba(6,214,160,0.1); color: var(--accent2); }
  .agent-status.idle { background: rgba(245,158,11,0.1); color: var(--accent3); }
  .agent-status.standby { background: var(--surface2); color: var(--muted); }

  /* Quiz section */
  .quiz-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
  }
  .quiz-q { font-size: 16px; font-weight: 500; margin-bottom: 20px; line-height: 1.5; }
  .quiz-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
  .quiz-opt {
    padding: 14px 18px;
    border-radius: 10px;
    border: 1.5px solid var(--border);
    cursor: pointer;
    font-size: 14px;
    transition: all 0.2s;
    background: var(--surface2);
  }
  .quiz-opt:hover { border-color: var(--accent); background: rgba(59,130,246,0.08); }
  .quiz-opt.selected { border-color: var(--accent); background: rgba(59,130,246,0.12); color: var(--accent); }
  .quiz-opt.correct { border-color: var(--accent2); background: rgba(6,214,160,0.1); color: var(--accent2); }
  .quiz-opt.wrong { border-color: #f87171; background: rgba(248,113,113,0.1); color: #f87171; }
  .quiz-btn {
    padding: 12px 28px;
    border-radius: 10px;
    border: none;
    background: linear-gradient(135deg, var(--accent), #6366f1);
    color: white;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: opacity 0.2s, transform 0.2s;
  }
  .quiz-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .quiz-feedback {
    margin-top: 16px;
    padding: 14px;
    border-radius: 10px;
    font-size: 13px;
    display: none;
    line-height: 1.6;
  }
  .quiz-feedback.show { display: block; }
  .quiz-feedback.correct-fb { background: rgba(6,214,160,0.1); border: 1px solid rgba(6,214,160,0.2); color: #6ee7b7; }
  .quiz-feedback.wrong-fb { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.2); color: #fca5a5; }

  /* Micro chart bars */
  .bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 60px;
  }
  .bar {
    flex: 1;
    border-radius: 4px 4px 0 0;
    transition: opacity 0.2s;
    min-width: 0;
  }
  .bar:hover { opacity: 0.7; }

  /* Skill radar placeholder */
  .skill-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 8px;
  }
  .skill-item {
    padding: 10px 12px;
    border-radius: 8px;
    background: var(--surface2);
    border: 1px solid var(--border);
  }
  .skill-name { font-size: 12px; color: var(--muted); margin-bottom: 6px; }
  .skill-score { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800; }

  /* Anim */
  .fade-in { animation: fadeIn 0.4s ease; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

  /* AURA chat */
  .chat-area {
    height: 260px;
    overflow-y: auto;
    padding: 16px;
    background: var(--surface2);
    border-radius: 10px;
    margin-bottom: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .msg {
    max-width: 80%;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 13px;
    line-height: 1.5;
  }
  .msg-aura {
    background: rgba(59,130,246,0.12);
    border: 1px solid rgba(59,130,246,0.2);
    align-self: flex-start;
  }
  .msg-user {
    background: var(--surface);
    border: 1px solid var(--border);
    align-self: flex-end;
  }
  .msg-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
  .msg-label-aura { color: var(--accent); }
  .msg-label-user { color: var(--muted); text-align: right; }
  .chat-input-row { display: flex; gap: 10px; }
  .chat-input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1.5px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
  }
  .chat-input:focus { border-color: var(--accent); }
  .chat-send {
    padding: 10px 18px;
    border-radius: 10px;
    border: none;
    background: var(--accent);
    color: white;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.2s;
  }
  .chat-send:hover { background: #2563eb; }

  /* Typing indicator */
  .typing {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 10px 14px;
    background: rgba(59,130,246,0.12);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 12px;
    align-self: flex-start;
    display: none;
  }
  .typing.show { display: flex; }
  .typing span {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: bounce 1.2s infinite;
  }
  .typing span:nth-child(2) { animation-delay: 0.15s; }
  .typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-6px)} }

  /* Section title */
  .page-title {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 4px;
  }
  .page-sub { font-size: 13px; color: var(--muted); margin-bottom: 24px; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

  /* ══════════ AGENT COMMAND CENTER ══════════ */
  .orch-bar {
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(135deg, rgba(59,130,246,0.12), rgba(99,102,241,0.08));
    border: 1px solid rgba(59,130,246,0.25); border-radius: 16px;
    padding: 14px 20px; margin-bottom: 16px; position: relative; overflow: hidden;
  }
  .orch-bar::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(59,130,246,0.025) 20px, rgba(59,130,246,0.025) 21px);
    pointer-events: none;
  }
  .orch-core { display: flex; align-items: center; gap: 16px; }
  .orch-icon {
    font-size: 26px; width: 52px; height: 52px;
    background: linear-gradient(135deg, #1d4ed8, #4f46e5); border-radius: 14px;
    display: grid; place-items: center;
    box-shadow: 0 0 30px rgba(59,130,246,0.4); position: relative; z-index: 1;
  }
  .orch-pulse {
    position: absolute; inset: -4px; border-radius: 18px;
    border: 2px solid rgba(59,130,246,0.4);
    animation: orchPulse 2s ease infinite; pointer-events: none;
  }
  @keyframes orchPulse { 0%,100%{opacity:.8;transform:scale(1)} 50%{opacity:.2;transform:scale(1.08)} }
  .orch-label {
    font-family:'Syne',sans-serif; font-size:15px; font-weight:800; letter-spacing:2px;
    background:linear-gradient(90deg,#93c5fd,#fff);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  }
  .orch-sub { font-size:12px; color:var(--muted); margin-top:3px; }
  .orch-btn {
    padding:9px 20px; border-radius:9px; border:none;
    background:linear-gradient(135deg,#2563eb,#4f46e5); color:white;
    font-size:13px; font-weight:600; cursor:pointer;
    font-family:'DM Sans',sans-serif; transition:all .2s;
    box-shadow:0 0 20px rgba(59,130,246,.3);
  }
  .orch-btn:hover { transform:translateY(-1px); box-shadow:0 0 30px rgba(59,130,246,.5); }
  .orch-btn-ghost {
    background:transparent; border:1.5px solid rgba(59,130,246,.3);
    color:var(--accent); box-shadow:none;
  }
  .orch-btn-ghost:hover { background:rgba(59,130,246,.1); box-shadow:none; }

  /* Network viz */
  .agent-network {
    position:relative; height:260px; margin-bottom:18px;
    border-radius:20px;
    background:radial-gradient(ellipse at center,rgba(59,130,246,.06) 0%,transparent 70%);
    border:1px solid var(--border); overflow:hidden;
  }
  #agentCanvas { position:absolute; inset:0; width:100%; height:100%; }
  .net-node {
    position:absolute; transform:translate(-50%,-50%);
    text-align:center; cursor:pointer; z-index:2; transition:transform .3s;
  }
  .net-node:hover { transform:translate(-50%,-50%) scale(1.12); }
  #net-orch { top:50%; left:50%; }
  #net-0 { top:20%; left:72%; }
  #net-1 { top:55%; left:80%; }
  #net-2 { top:82%; left:62%; }
  #net-3 { top:82%; left:38%; }
  #net-4 { top:55%; left:20%; }
  .net-node-glow {
    position:absolute; inset:-10px; border-radius:50%;
    background:radial-gradient(circle, var(--c,rgba(59,130,246,.3)), transparent 70%);
    opacity:0; transition:opacity .3s;
  }
  .net-node:hover .net-node-glow, .net-node.net-active .net-node-glow { opacity:1; }
  .net-node-icon {
    width:52px; height:52px; border-radius:50%; background:var(--surface2);
    border:2px solid var(--border); display:grid; place-items:center;
    font-size:20px; margin:0 auto 6px; transition:border-color .3s,box-shadow .3s; position:relative; z-index:1;
  }
  .net-node.net-active .net-node-icon { border-color:var(--accent); box-shadow:0 0 20px rgba(59,130,246,.5); }
  #net-orch .net-node-icon {
    width:66px; height:66px; font-size:28px;
    background:linear-gradient(135deg,#1d4ed8,#4f46e5);
    border-color:rgba(59,130,246,.5); box-shadow:0 0 30px rgba(59,130,246,.35);
  }
  .net-node-label { font-size:10px; color:var(--muted); line-height:1.3; font-weight:500; max-width:75px; }
  #net-orch .net-node-label { color:var(--accent); font-size:11px; font-weight:600; }

  /* Agent cards */
  .agents-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(210px, 1fr));
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 6px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .agent-card {
    background:var(--surface); border:1.5px solid var(--border);
    border-radius:16px; padding:14px 16px; cursor:pointer;
    transition:all .25s; position:relative; overflow:hidden; min-width:0;
  }
  .agent-card::before {
    content:''; position:absolute; top:0; left:0; right:0; height:2px; opacity:0; transition:opacity .3s;
  }
  .agent-card:nth-child(1)::before { background:linear-gradient(90deg,#3b82f6,#6366f1); }
  .agent-card:nth-child(2)::before { background:linear-gradient(90deg,#06d6a0,#3b82f6); }
  .agent-card:nth-child(3)::before { background:linear-gradient(90deg,#f59e0b,#f97316); }
  .agent-card:nth-child(4)::before { background:linear-gradient(90deg,#ec4899,#8b5cf6); }
  .agent-card:nth-child(5)::before { background:linear-gradient(90deg,#a78bfa,#ec4899); }
  .agent-card:hover::before, .agent-card.ac-active::before { opacity:1; }
  .agent-card:hover { transform:translateY(-3px); border-color:rgba(100,180,255,.22); box-shadow:0 8px 30px rgba(0,0,0,.3); }
  .agent-card.ac-active { border-color:rgba(59,130,246,.35); box-shadow:0 0 30px rgba(59,130,246,.15); }

  .ac-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
  .ac-icon { width:38px; height:38px; border-radius:10px; display:grid; place-items:center; font-size:18px; border:1px solid transparent; }
  .ac-badge { font-size:10px; padding:3px 8px; border-radius:100px; font-weight:600; letter-spacing:.5px; }
  .ac-badge-blue { background:rgba(59,130,246,.15); color:#60a5fa; border:1px solid rgba(59,130,246,.3); }
  .ac-badge-green { background:rgba(6,214,160,.12); color:#34d399; border:1px solid rgba(6,214,160,.25); }
  .ac-badge-amber { background:rgba(245,158,11,.12); color:#fbbf24; border:1px solid rgba(245,158,11,.25); }
  .ac-badge-pink { background:rgba(236,72,153,.12); color:#f472b6; border:1px solid rgba(236,72,153,.25); }

  .ac-name { font-family:'Syne',sans-serif; font-size:13px; font-weight:700; margin-bottom:6px; line-height:1.3; }
  .ac-desc { font-size:11px; color:var(--muted); line-height:1.6; margin-bottom:14px; }

  .ac-stats { display:flex; margin-bottom:10px; background:var(--surface2); border-radius:8px; overflow:hidden; }
  .ac-stat { flex:1; padding:6px 4px; text-align:center; border-right:1px solid var(--border); }
  .ac-stat:last-child { border-right:none; }
  .ac-stat-val { font-family:'Syne',sans-serif; font-size:14px; font-weight:800; }
  .ac-stat-key { font-size:9px; color:var(--muted); margin-top:2px; text-transform:uppercase; letter-spacing:.5px; }

  .ac-actions { display:flex; gap:6px; margin-bottom:8px; }
  .ac-btn {
    flex:1; padding:6px 0; border-radius:7px; border:none;
    font-size:11px; font-weight:600; cursor:pointer;
    font-family:'DM Sans',sans-serif; transition:all .2s;
    display:inline-flex; align-items:center; justify-content:center;
  }
  .ac-btn-wide {
    display:flex; align-items:center; justify-content:center;
    width:100%; margin-top:7px; padding:8px 0;
    border-radius:8px; border:none; font-size:12px; font-weight:600;
    cursor:pointer; font-family:'DM Sans',sans-serif; transition:all .2s;
    gap:6px;
  }
  .ac-btn-wide:hover { opacity:0.85; transform:translateY(-1px); }
  .ac-btn-wide-blue  { background:rgba(59,130,246,0.15); color:#93c5fd; border:1px solid rgba(59,130,246,0.35); }
  .ac-btn-wide-green { background:rgba(6,214,160,0.15);  color:#6ee7b7; border:1px solid rgba(6,214,160,0.35); }
  .ac-btn-wide-amber { background:rgba(245,158,11,0.15); color:#fbbf24; border:1px solid rgba(245,158,11,0.35); }

  /* ══════ MODAL ══════ */
  .modal-overlay {
    display:none; position:fixed; inset:0;
    background:rgba(4,7,15,0.88); backdrop-filter:blur(6px);
    z-index:2000; align-items:center; justify-content:center;
  }
  .modal-overlay.open { display:flex; }
  .modal-box {
    background:var(--surface); border:1px solid rgba(100,180,255,0.15);
    border-radius:20px; padding:28px;
    width:92vw; max-width:980px; max-height:88vh; overflow-y:auto;
    position:relative; box-shadow:0 0 60px rgba(59,130,246,0.18);
    animation:fadeIn 0.25s ease;
  }
  .modal-box.modal-sm { max-width:560px; }
  .modal-close {
    position:absolute; top:16px; right:16px;
    background:var(--surface2); border:1px solid var(--border);
    color:var(--muted); width:30px; height:30px; border-radius:8px;
    cursor:pointer; font-size:15px; display:grid; place-items:center; transition:all .2s;
  }
  .modal-close:hover { color:var(--text); }
  .modal-title { font-family:'Syne',sans-serif; font-size:18px; font-weight:800; margin-bottom:4px; }
  .modal-sub { font-size:12px; color:var(--muted); margin-bottom:18px; }

  /* ══════ SUBJECT MAP ══════ */
  .sm-wrap { overflow-x:auto; border:1px solid var(--border); border-radius:12px; background:var(--surface2); }
  .sm-grid {
    display:grid; grid-template-columns:repeat(5,190px);
    gap:0; padding:20px; width:max-content; min-width:100%;
  }
  .sm-col-hd {
    font-size:10px; text-transform:uppercase; letter-spacing:1.5px;
    color:var(--muted); text-align:center; padding:6px 4px 14px;
    font-weight:700; border-bottom:1px solid var(--border); margin-bottom:8px;
  }
  .sm-node {
    margin:5px 8px; padding:10px 11px; border-radius:10px;
    font-size:11.5px; font-weight:500; text-align:center;
    line-height:1.4; cursor:default; transition:transform .15s;
  }
  .sm-node:hover { transform:translateY(-2px); }
  .sm-node .sm-badge { display:block; font-size:9.5px; margin-top:5px; opacity:.85; }
  .sm-done   { background:rgba(6,214,160,0.1);  border:1px solid rgba(6,214,160,0.3);  color:#6ee7b7; }
  .sm-active { background:rgba(59,130,246,0.12); border:1.5px solid rgba(59,130,246,0.5); color:#93c5fd; box-shadow:0 0 12px rgba(59,130,246,.15); }
  .sm-warn   { background:rgba(245,158,11,0.1);  border:1px solid rgba(245,158,11,0.3); color:#fbbf24; }
  .sm-locked { background:var(--surface);         border:1px solid var(--border);         color:var(--muted); }
  .sm-legend { display:flex; gap:14px; flex-wrap:wrap; margin-bottom:14px; }
  .sm-legend-item { display:flex; align-items:center; gap:7px; font-size:12px; color:var(--muted); }
  .sm-leg-dot { width:10px; height:10px; border-radius:3px; }

  /* Subject tabs */
  .sm-tab {
    padding:8px 16px; border-radius:8px; border:1px solid var(--border);
    background:var(--surface2); color:var(--muted);
    font-size:12px; font-weight:600; cursor:pointer;
    font-family:'DM Sans',sans-serif; transition:all .2s;
  }
  .sm-tab:hover { color:var(--text); border-color:rgba(100,180,255,0.3); }
  .sm-tab.active { background:rgba(59,130,246,0.15); color:#93c5fd; border-color:rgba(59,130,246,0.5); }

  /* Agent tabs */
  .agent-tab {
    padding:10px 18px; border-radius:10px; border:1px solid var(--border);
    background:var(--surface2); color:var(--muted);
    font-size:13px; font-weight:600; cursor:pointer;
    font-family:'DM Sans',sans-serif; transition:all .2s;
    display:flex; align-items:center; gap:7px;
  }
  .agent-tab:hover { color:var(--text); border-color:rgba(255,255,255,0.15); }
  .agent-tab.active {
    background:rgba(59,130,246,0.12); color:var(--text);
    border-color:rgba(59,130,246,0.4);
    box-shadow:0 0 16px rgba(59,130,246,0.15);
  }
  .agent-tab-panel { display:none; }
  .agent-tab-panel.active { display:block; animation:fadeIn .25s ease; }

  /* ══════ QUICK QUIZ ══════ */
  .qq-ring {
    width:72px; height:72px; border-radius:50%; display:grid; place-items:center;
    margin:0 auto 18px;
    background:conic-gradient(var(--accent2) 100%, rgba(255,255,255,0.05) 0);
    transition:background .4s; position:relative;
  }
  .qq-ring::before { content:''; position:absolute; inset:9px; border-radius:50%; background:var(--surface); }
  .qq-ring-val { font-family:'Syne',sans-serif; font-size:20px; font-weight:800; position:relative; z-index:1; color:var(--accent2); }
  .qq-q { font-size:15px; font-weight:500; margin-bottom:16px; line-height:1.55; }
  .qq-opts { display:flex; flex-direction:column; gap:8px; margin-bottom:14px; }
  .qq-opt {
    padding:11px 15px; border-radius:9px; border:1.5px solid var(--border);
    cursor:pointer; font-size:13px; transition:all .18s; background:var(--surface2);
  }
  .qq-opt:hover:not(.qq-locked){ border-color:var(--accent); background:rgba(59,130,246,.08); }
  .qq-opt.qq-selected{ border-color:var(--accent); background:rgba(59,130,246,.12); color:var(--accent); }
  .qq-opt.qq-correct { border-color:var(--accent2); background:rgba(6,214,160,.1); color:var(--accent2); }
  .qq-opt.qq-wrong   { border-color:#f87171; background:rgba(248,113,113,.08); color:#f87171; }
  .qq-dots { display:flex; gap:6px; justify-content:center; margin-bottom:16px; }
  .qq-dot { width:8px; height:8px; border-radius:50%; background:var(--surface2); border:1px solid var(--border); transition:background .2s; }
  .qq-dot.qd-correct { background:var(--accent2); border-color:var(--accent2); }
  .qq-dot.qd-wrong   { background:#f87171; border-color:#f87171; }
  .qq-dot.qd-cur     { background:var(--accent); border-color:var(--accent); }
  .qq-footer { display:flex; align-items:center; justify-content:space-between; margin-top:14px; }
  .qq-fb { margin-top:12px; padding:12px 14px; border-radius:9px; font-size:12.5px; line-height:1.55; display:none; }
  .qq-fb.show { display:block; }
  .qq-fb.fb-ok  { background:rgba(6,214,160,.1); border:1px solid rgba(6,214,160,.2); color:#6ee7b7; }
  .qq-fb.fb-bad { background:rgba(248,113,113,.08); border:1px solid rgba(248,113,113,.2); color:#fca5a5; }
  .qq-score-screen { text-align:center; padding:20px 0; display:none; }
  .qq-score-screen.show { display:block; }
  .qq-score-big { font-family:'Syne',sans-serif; font-size:54px; font-weight:800; margin-bottom:8px; }
  .ac-btn-primary { background:rgba(59,130,246,.2); color:#60a5fa; border:1px solid rgba(59,130,246,.3); }
  .ac-btn-primary:hover { background:rgba(59,130,246,.35); }
  .ac-btn-green { background:rgba(6,214,160,.15); color:#34d399; border:1px solid rgba(6,214,160,.25); }
  .ac-btn-green:hover { background:rgba(6,214,160,.28); }
  .ac-btn-amber { background:rgba(245,158,11,.15); color:#fbbf24; border:1px solid rgba(245,158,11,.25); }
  .ac-btn-amber:hover { background:rgba(245,158,11,.28); }
  .ac-btn-pink { background:rgba(236,72,153,.15); color:#f472b6; border:1px solid rgba(236,72,153,.25); }
  .ac-btn-pink:hover { background:rgba(236,72,153,.28); }
  .ac-btn-ghost { background:transparent; color:var(--muted); border:1px solid var(--border); }
  .ac-btn-ghost:hover { color:var(--text); border-color:rgba(100,180,255,.2); }

  .ac-output { font-size:11px; color:var(--muted); min-height:28px; line-height:1.6; margin-bottom:8px; font-family:'Courier New',monospace; transition:color .3s; }
  .ac-output.running { color:var(--accent2); }
  .ac-output.done { color:var(--text); }

  .ac-progress-bar { height:3px; background:var(--surface2); border-radius:100px; overflow:hidden; }
  .ac-progress-fill { height:100%; border-radius:100px; transition:width .08s linear; }

  /* ── Dual view toggle ── */
  .view-toggle {
    display: flex; background: var(--surface2);
    border: 1px solid var(--border); border-radius: 8px; overflow: hidden; padding: 3px; gap: 3px;
  }
  .vtoggle {
    padding: 5px 14px; border-radius: 6px; border: none;
    background: transparent; color: var(--muted);
    font-size: 12px; font-weight: 500; cursor: pointer;
    font-family: 'DM Sans', sans-serif; transition: all .2s;
  }
  .vtoggle.active { background: var(--surface); color: var(--text); box-shadow: 0 1px 4px rgba(0,0,0,0.3); }

  /* Dual view inside each card */
  .dual-view { display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
  .dv-simple, .dv-tech {
    padding: 8px 10px; border-radius: 8px; font-size: 10.5px; line-height: 1.55;
  }
  .dv-simple { background: rgba(6,214,160,0.05); border: 1px solid rgba(6,214,160,0.12); }
  .dv-tech   { background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.12); }
  .dv-label  { font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  .dv-label-simple { color: var(--accent2); }
  .dv-label-tech   { color: var(--accent); }
  .dv-text   { color: var(--muted); }

  /* View visibility classes */
  .view-both   { display: block; }
  .view-simple { display: none; }
  .view-tech   { display: none; }
  body.mode-both   .view-both   { display: block; }
  body.mode-simple .view-simple { display: block; }
  body.mode-tech   .view-tech   { display: block; }
  body.mode-both   .view-simple, body.mode-both   .view-tech   { display: none; }
  body.mode-simple .view-both,   body.mode-simple .view-tech   { display: none; }
  body.mode-tech   .view-both,   body.mode-tech   .view-simple { display: none; }

  /* Default: both visible */
  .view-simple, .view-both, .view-tech { display: block; }

  /* ac-output now holds two sub-divs */
  .ac-output { min-height: 32px; margin-bottom: 8px; transition: color .3s; }
  .ao-simple { font-size: 11px; color: var(--muted); line-height: 1.6; }
  .ao-tech   { font-size: 10px; color: var(--muted); font-family: 'Courier New', monospace; line-height: 1.7; }
  .ao-simple.running { color: var(--accent2); }
  .ao-tech.running   { color: var(--accent); }

  /* ══════ INTRO SCREEN ══════ */
  #introScreen {
    position: fixed; inset: 0; z-index: 9999;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column;
    overflow: hidden;
  }
  #introScreen::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }
  .intro-blob1 { position:absolute; width:500px; height:500px; border-radius:50%; background:#1e40af; top:-150px; right:-100px; filter:blur(90px); opacity:0.2; }
  .intro-blob2 { position:absolute; width:400px; height:400px; border-radius:50%; background:#065f46; bottom:-100px; left:-80px; filter:blur(90px); opacity:0.2; }
  .intro-content { position:relative; z-index:1; text-align:center; max-width:640px; padding:0 24px; animation: fadeIn 0.8s ease; }
  .intro-badge {
    display:inline-flex; align-items:center; gap:8px;
    background:rgba(59,130,246,0.1); border:1px solid rgba(59,130,246,0.3);
    border-radius:100px; padding:6px 16px; font-size:12px; color:var(--accent);
    margin-bottom:28px; letter-spacing:0.5px;
  }
  .intro-logo {
    width:72px; height:72px;
    background:linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius:20px; display:grid; place-items:center;
    font-size:32px; margin:0 auto 24px;
    box-shadow: 0 0 40px rgba(59,130,246,0.4);
  }
  .intro-title {
    font-family:'Syne',sans-serif; font-size:52px; font-weight:800;
    line-height:1.1; margin-bottom:16px;
    background:linear-gradient(135deg, #fff 30%, #94a3b8);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  }
  .intro-sub { font-size:16px; color:var(--muted); line-height:1.7; margin-bottom:36px; max-width:500px; margin-left:auto; margin-right:auto; }
  .intro-pills { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-bottom:40px; }
  .intro-pill { padding:7px 16px; border-radius:100px; font-size:12px; font-weight:600; border:1px solid; display:flex; align-items:center; gap:6px; }
  .intro-pill-blue   { background:rgba(59,130,246,0.1);  color:#93c5fd; border-color:rgba(59,130,246,0.3); }
  .intro-pill-green  { background:rgba(6,214,160,0.1);   color:#6ee7b7; border-color:rgba(6,214,160,0.3); }
  .intro-pill-amber  { background:rgba(245,158,11,0.1);  color:#fbbf24; border-color:rgba(245,158,11,0.3); }
  .intro-pill-pink   { background:rgba(236,72,153,0.1);  color:#f472b6; border-color:rgba(236,72,153,0.3); }
  .intro-pill-purple { background:rgba(167,139,250,0.1); color:#c4b5fd; border-color:rgba(167,139,250,0.3); }
  .intro-cta {
    display:inline-flex; align-items:center; gap:10px;
    padding:16px 36px; border-radius:14px; border:none;
    background:linear-gradient(135deg, var(--accent), #6366f1);
    color:white; font-size:16px; font-weight:700;
    font-family:'DM Sans',sans-serif; cursor:pointer;
    box-shadow:0 0 40px rgba(59,130,246,0.4);
    transition:all .25s; letter-spacing:0.3px;
  }
  .intro-cta:hover { transform:translateY(-2px); box-shadow:0 0 60px rgba(59,130,246,0.6); }
  .intro-cta-sub { font-size:12px; color:var(--muted); margin-top:14px; }
  .intro-stats { display:flex; gap:32px; justify-content:center; margin-top:48px; padding-top:32px; border-top:1px solid var(--border); flex-wrap:wrap; }
  .intro-stat-val { font-family:'Syne',sans-serif; font-size:28px; font-weight:800; }
  .intro-stat-lbl { font-size:11px; color:var(--muted); margin-top:3px; text-transform:uppercase; letter-spacing:1px; }
  #introScreen.hide { animation: introFadeOut 0.5s ease forwards; }
  @keyframes introFadeOut { to { opacity:0; transform:scale(1.03); pointer-events:none; } }

  /* ══════ MOBILE BANNER ══════ */
  #mobileBanner {
    display:none; position:fixed; bottom:0; left:0; right:0; z-index:5000;
    background:linear-gradient(135deg,rgba(14,20,32,0.98),rgba(19,27,42,0.98));
    border-top:1px solid rgba(59,130,246,0.3);
    padding:16px 20px; backdrop-filter:blur(12px);
    box-shadow:0 -4px 30px rgba(0,0,0,0.4);
    align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;
  }
  #mobileBanner.show { display:flex; }
  .mb-text { font-size:13px; color:var(--text); flex:1; min-width:180px; }
  .mb-text strong { color:var(--accent2); }
  .mb-btn { padding:9px 18px; border-radius:9px; border:none; cursor:pointer; font-size:13px; font-weight:600; font-family:'DM Sans',sans-serif; transition:all .2s; white-space:nowrap; }
  .mb-btn-primary { background:linear-gradient(135deg,var(--accent),#6366f1); color:white; }
  .mb-btn-ghost   { background:transparent; color:var(--muted); border:1px solid var(--border); }
  .mb-btn:hover   { opacity:0.85; }

  /* ══════ MOBILE LAYOUT ══════ */
  body.mobile-mode .layout { grid-template-columns:1fr; }
  body.mobile-mode .sidebar { display:none; }
  body.mobile-mode .mobile-nav { display:flex !important; }
  body.mobile-mode .topbar { padding:12px 16px; }
  body.mobile-mode .content { padding:14px; padding-bottom:80px; }
  body.mobile-mode .stats-grid { grid-template-columns:1fr 1fr; }
  body.mobile-mode .grid-2, body.mobile-mode .grid-3 { grid-template-columns:1fr; }
  body.mobile-mode .agents-row { grid-template-columns:1fr; }
  body.mobile-mode .agent-card { min-width:unset; }
  body.mobile-mode .intro-title { font-size:36px; }

  /* Mobile bottom nav */
  .mobile-nav {
    display:none; position:fixed; bottom:0; left:0; right:0;
    background:var(--surface); border-top:1px solid var(--border);
    z-index:100; padding:8px 0 12px;
  }
  .mobile-nav-inner { display:flex; justify-content:space-around; }
