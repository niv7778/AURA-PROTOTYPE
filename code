      if(tEl){tEl.className='ao-tech running';tEl.textContent='';}
      if(prog) prog.style.width='0%';
      const total = a.stepsSimple.length;
      for(let i=0;i<total;i++){
        setTimeout(()=>{
          if(sEl) sEl.textContent=a.stepsSimple[i];
          if(tEl) tEl.textContent=a.stepsTech[i];
          if(prog) prog.style.width=((i+1)/total*100)+'%';
