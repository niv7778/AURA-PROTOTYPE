  ];
  const CENTER = { x: 0.50, y: 0.50 };

  function initCanvas() {
    const canvas = document.getElementById('agentCanvas');
    if (!canvas) return;
    const container = canvas.parentElement;
    canvas.width  = container.offsetWidth  || 800;
    canvas.height = container.offsetHeight || 300;
    // Reposition net-node elements to match canvas coords
    for (let i = 0; i < 5; i++) {
      const el = document.getElementById('net-' + i);
      if (!el) continue;
      el.style.left = (NODE_POS[i].x * 100) + '%';
      el.style.top  = (NODE_POS[i].y * 100) + '%';
    }
    const orch = document.getElementById('net-orch');
    if (orch) { orch.style.left = '50%'; orch.style.top = '50%'; }
    drawConnections(canvas);
  }

  function drawConnections(canvas) {
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);
    const cx = CENTER.x * W, cy = CENTER.y * H;
    const nodeColors = ['#3b82f6','#06d6a0','#f59e0b','#ec4899','#a78bfa'];

    for (let i = 0; i < 5; i++) {
      const nx = NODE_POS[i].x * W, ny = NODE_POS[i].y * H;
      const isActive = activeAgent === i;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(nx, ny);
      if (isActive) {
        ctx.strokeStyle = nodeColors[i];
        ctx.lineWidth = 2;
        ctx.setLineDash([]);
        // Glowing effect
        ctx.shadowColor = nodeColors[i];
        ctx.shadowBlur = 8;
      } else {
        ctx.strokeStyle = 'rgba(100,130,180,0.18)';
        ctx.lineWidth = 1;
        ctx.setLineDash([5, 7]);
        ctx.shadowBlur = 0;
      }
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.shadowBlur = 0;
    }

    // Draw animated packets
    packets.forEach(p => {
      const px = p.fx * W, py = p.fy * H;
      ctx.beginPath();
      ctx.arc(px, py, 5, 0, Math.PI * 2);
      ctx.fillStyle = p.color;
      ctx.shadowColor = p.color;
      ctx.shadowBlur = 12;
      ctx.fill();
      ctx.shadowBlur = 0;
    });
  }

  function animatePacket(agentIdx) {
    const canvas = document.getElementById('agentCanvas');
    if (!canvas) return;
    const color = agentData[agentIdx].color;
    const goingOut = Math.random() > 0.5;
    const startF = goingOut ? { ...CENTER } : { ...NODE_POS[agentIdx] };
    const endF   = goingOut ? { ...NODE_POS[agentIdx] } : { ...CENTER };
    let t = 0;
    const pkt = { fx: startF.x, fy: startF.y, color };
    packets.push(pkt);
    const step = () => {
      t += 0.035;
      if (t >= 1) {
        packets = packets.filter(p => p !== pkt);
        drawConnections(canvas);
        return;
      }
      pkt.fx = startF.x + (endF.x - startF.x) * t;
      pkt.fy = startF.y + (endF.y - startF.y) * t;
      drawConnections(canvas);
      requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

