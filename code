    canvas.height = H;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, W, H);

    const data   = [58, 63, 61, 68, 72, 74];
    const labels = ['W1', 'W2', 'W3', 'W4', 'W5', 'Now'];
    const PAD_L = 36, PAD_R = 16, PAD_T = 16, PAD_B = 28;
    const chartW = W - PAD_L - PAD_R;
    const chartH = H - PAD_T - PAD_B;
    const minV = 40, maxV = 100;

    function xPos(i) { return PAD_L + (i / (data.length - 1)) * chartW; }
    function yPos(v) { return PAD_T + chartH - ((v - minV) / (maxV - minV)) * chartH; }

    // Grid lines + y labels
    [40, 50, 60, 70, 80, 90, 100].forEach(v => {
      const y = yPos(v);
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(100,130,180,0.1)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      ctx.moveTo(PAD_L, y); ctx.lineTo(W - PAD_R, y);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = '#4b5a72';
      ctx.font = '9px DM Sans, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(v + '%', PAD_L - 4, y + 3);
    });

    // Gradient fill under line
    const grad = ctx.createLinearGradient(0, PAD_T, 0, H - PAD_B);
    grad.addColorStop(0, 'rgba(6,214,160,0.25)');
    grad.addColorStop(1, 'rgba(6,214,160,0.01)');
    ctx.beginPath();
    ctx.moveTo(xPos(0), yPos(data[0]));
    data.forEach((v, i) => {
      if (i === 0) return;
      const x0 = xPos(i-1), y0 = yPos(data[i-1]);
      const x1 = xPos(i),   y1 = yPos(v);
      const cpx = (x0 + x1) / 2;
      ctx.bezierCurveTo(cpx, y0, cpx, y1, x1, y1);
    });
    ctx.lineTo(xPos(data.length - 1), H - PAD_B);
    ctx.lineTo(xPos(0), H - PAD_B);
    ctx.closePath();
    ctx.fillStyle = grad;
    ctx.fill();

    // Line
    ctx.beginPath();
    ctx.moveTo(xPos(0), yPos(data[0]));
    data.forEach((v, i) => {
      if (i === 0) return;
      const x0 = xPos(i-1), y0 = yPos(data[i-1]);
      const x1 = xPos(i),   y1 = yPos(v);
      const cpx = (x0 + x1) / 2;
      ctx.bezierCurveTo(cpx, y0, cpx, y1, x1, y1);
    });
    ctx.strokeStyle = '#06d6a0';
    ctx.lineWidth = 2.5;
    ctx.stroke();

    // Dots + labels
    data.forEach((v, i) => {
      const x = xPos(i), y = yPos(v);
      const isNow = i === data.length - 1;

      // Glow for last point
      if (isNow) { ctx.shadowColor = '#06d6a0'; ctx.shadowBlur = 12; }

      ctx.beginPath();
      ctx.arc(x, y, isNow ? 6 : 4, 0, Math.PI * 2);
      ctx.fillStyle = isNow ? '#06d6a0' : '#0e1420';
      ctx.fill();
      ctx.strokeStyle = isNow ? '#06d6a0' : '#3b82f6';
      ctx.lineWidth = 2;
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Value label above dot
      ctx.fillStyle = isNow ? '#06d6a0' : '#6b7a95';
      ctx.font = (isNow ? 'bold ' : '') + '10px DM Sans, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(v + '%', x, y - 10);

      // X label
      ctx.fillStyle = isNow ? '#06d6a0' : '#4b5a72';
      ctx.font = isNow ? 'bold 10px DM Sans, sans-serif' : '10px DM Sans, sans-serif';
      ctx.fillText(labels[i], x, H - 6);
    });
  }

</script>
