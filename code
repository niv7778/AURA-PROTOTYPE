  function smDrawTab(idx){
    const subj = SM_SUBJECTS[idx];
    const canvas = document.getElementById('smCanvas');
    if(!canvas) return;
    const W = canvas.parentElement.offsetWidth;

    const NW = Math.min(240, W * 0.55);
    const NH = 64;
    const R = 12;
    const GAP = 52; // space between nodes
    const PAD = 36; // top/bottom padding
    const H = PAD * 2 + subj.nodes.length * NH + (subj.nodes.length - 1) * GAP;

    canvas.width = W;
    canvas.height = H;
    canvas.style.height = H + 'px';

    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, W, H);

    const nodes = subj.nodes;
    const accent = subj.color;
    const cx = W / 2;

    nodes.forEach((n, i) => {
      n.px = cx;
      n.py = PAD + i * (NH + GAP) + NH / 2;
    });

    const sc = {done:'#06d6a0', active:'#3b82f6', warn:'#f59e0b', locked:'#1e2a3d'};
    const ss = {done:'#06d6a0', active:'#3b82f6', warn:'#f59e0b', locked:'#2e3f58'};
    const st = {done:'#d1fae5', active:'#dbeafe', warn:'#fef3c7', locked:'#3d5068'};
    const sl = {done:'✓ Mastered', active:'→ In Progress', warn:'⚠ Needs Review', locked:'🔒 Locked'};

    // Draw arrows
    nodes.forEach((n, i) => {
      if (i === 0) return;
      const p = nodes[i - 1];
      const x1 = p.px, y1 = p.py + NH / 2 + 2;
      const x2 = n.px, y2 = n.py - NH / 2 - 2;
      const isLocked = n.s === 'locked';
      const midY = (y1 + y2) / 2;

      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.bezierCurveTo(x1, midY, x2, midY, x2, y2);
      ctx.strokeStyle = isLocked ? 'rgba(80,110,160,0.2)' : accent + 'aa';
      ctx.lineWidth = isLocked ? 1.5 : 2.5;
      ctx.setLineDash(isLocked ? [5, 5] : []);
      ctx.stroke();
      ctx.setLineDash([]);

      // Arrowhead
      ctx.beginPath();
      ctx.moveTo(x2, y2);
      ctx.lineTo(x2 - 7, y2 - 12);
      ctx.lineTo(x2 + 7, y2 - 12);
      ctx.closePath();
      ctx.fillStyle = isLocked ? 'rgba(80,110,160,0.2)' : accent + 'cc';
      ctx.fill();
    });

    // Draw nodes
    nodes.forEach(n => {
      const x = n.px - NW / 2;
      const y = n.py - NH / 2;

      if (n.s !== 'locked') {
        ctx.shadowColor = sc[n.s] + '55';
        ctx.shadowBlur = 20;
      }

      ctx.beginPath();
      ctx.roundRect(x, y, NW, NH, R);
      ctx.fillStyle = n.s === 'locked' ? '#0d1625' : sc[n.s] + '18';
      ctx.fill();

      ctx.strokeStyle = ss[n.s];
      ctx.lineWidth = n.s === 'active' ? 2.5 : 1.5;
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Status strip
      ctx.beginPath();
      ctx.roundRect(x, y, NW, 17, [R, R, 0, 0]);
      ctx.fillStyle = n.s === 'locked' ? 'rgba(255,255,255,0.03)' : sc[n.s] + '28';
      ctx.fill();

      ctx.font = 'bold 9.5px DM Sans, sans-serif';
      ctx.fillStyle = n.s === 'locked' ? '#3d5068' : sc[n.s];
      ctx.textAlign = 'center';
      ctx.fillText(sl[n.s], n.px, y + 12);

      // Topic label
      ctx.fillStyle = st[n.s];
      ctx.font = (n.s === 'active' ? '700' : '500') + ' 13px DM Sans, sans-serif';
      const lines = n.label.split('\n');
      const lh = 17;
      const textStartY = n.py - ((lines.length - 1) * lh) / 2 + 7;
      lines.forEach((l, i) => ctx.fillText(l, n.px, textStartY + i * lh));
    });

    canvas._smNodes = nodes;
    canvas._NW = NW;
    canvas._NH = NH;

    const cnt = {done:0, active:0, warn:0, locked:0};
    nodes.forEach(n => cnt[n.s]++);
    document.getElementById('smStats').innerHTML = `
      <span style="font-size:12px;color:var(--muted)">✅ <strong style="color:var(--text)">${cnt.done}</strong> mastered</span>
      ${cnt.active ? `<span style="font-size:12px;color:var(--muted)">🔵 <strong style="color:var(--text)">${cnt.active}</strong> in progress</span>` : ''}
      ${cnt.warn ? `<span style="font-size:12px;color:var(--accent3)">⚠️ <strong>${cnt.warn}</strong> needs review</span>` : ''}
      <span style="font-size:12px;color:var(--muted)">🔒 <strong>${cnt.locked}</strong> locked</span>
      <span style="margin-left:auto;font-size:11px;color:${accent};font-weight:700">${subj.name}</span>`;
  }

